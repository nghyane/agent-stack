# Server
APP_ENV=development
APP_PORT=8080

# Database (dev compose maps Postgres to 5433 to avoid clashing with a local instance)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/app?sslmode=disable

# Session / Auth
# Sessions are stored server-side in Postgres (scs + pgxstore); the cookie holds
# only a random token, so no signing secret is needed.
# Comma-separated allowed origins for CORS (Cloudflare Pages domains)
CORS_ORIGINS=http://localhost:5173
